# =============================================================================
#  eBay API keys — COPY this file to a new file named ".env" and fill in values.
#  (In a terminal:  cp .env.example .env  )
#
#  You get these from https://developer.ebay.com after signing up with the SAME
#  account you already sell with. See docs/01-getting-ebay-api-keys.md for the
#  click-by-click walkthrough.
#
#  NEVER share your .env file or commit it to GitHub. The .gitignore already
#  hides it for you.
# =============================================================================

# ---- Which eBay environment to use ----
# Start with "sandbox" (a fake practice eBay) while testing.
# Switch to "production" (the real eBay) once you're ready to list for real.
EBAY_ENV=sandbox

# ---- Your app keys (from developer.ebay.com -> "Application Keysets") ----
# You'll have one set for Sandbox and one set for Production.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ---- User token (lets the app act on YOUR selling account) ----
# Generated with eBay's "user token" flow — see docs/01-getting-ebay-api-keys.md.
EBAY_USER_REFRESH_TOKEN=

# ---- Business defaults used when creating listings ----
# eBay policy IDs (payment, shipping, return) — from your Seller Hub -> Business Policies.
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_MERCHANT_LOCATION_KEY=
